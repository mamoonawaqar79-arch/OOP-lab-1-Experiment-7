#include <iostream>
using namespace std;
class Student {
    string name;
    int rollNo;
public:
    void input() {
        cout << "Enter Name: ";
        cin >> name;
        cout << "Enter Roll No: ";
        cin >> rollNo;
    }
void display() {
        cout << "\nStudent Information" << endl;
        cout << "Name: " << name << endl;
        cout << "Roll No: " << rollNo << endl;
    }
};

int main() {
    Student s;
    s.input();
    s.display();

    return 0;
}
